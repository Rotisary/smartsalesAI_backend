# App
APP_ENV=development
SECRET_KEY=change_me_to_a_long_random_secret
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://smartsales:secret@localhost:5432/smartsales

# Redis (conversation context cache)
REDIS_URL=redis://localhost:6379

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# WhatsApp Cloud API (Meta)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token
WHATSAPP_API_VERSION=v19.0
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
WHATSAPP_TOKEN_ENCRYPTION_KEY=your_fernet_key

# s3
AWS_REGION=your_s3_bucket_region
AWS_ACCESS_KEY_ID=your_s3_access_id
AWS_SECRET_ACCESS_KEY=your_s3_secret_key
S3_BUCKET_NAME=your_s3_bucket_name

# Business defaults
DEFAULT_AI_PERSONA_NAME=Aria
DEFAULT_BUSINESS_NAME=Acme Store

# Knowledge document
MAX_FILE_SIZE_BYTES=52428800
PRESIGNED_URL_TTL=300

# embedding
EMBEDDING_MODEL=models/text-embedding-0044

